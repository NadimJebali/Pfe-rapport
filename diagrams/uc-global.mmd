flowchart LR
    C((("Customer")))
    S((("Seller")))
    A((("Administrator")))

    subgraph SYS["Cheebo Marketplace"]
      direction TB
      UC_AUTH(["Register / Log in"])
      UC_BROWSE(["Browse catalogue"])
      UC_ORDER(["Place an order"])
      UC_CHAT(["Chat with AI assistant"])
      UC_APPLY(["Apply to become a seller"])
      UC_STORE(["Manage store"])
      UC_PROD(["Manage products"])
      UC_AN(["View seller analytics"])
      UC_UPG(["Upgrade to premium tier"])
      UC_SALE(["Run store promotion"])
      UC_REV(["Review seller applications"])
      UC_MOD(["Moderate stores & products"])
      UC_SUSP(["Suspend / delete store"])
      UC_FEAT(["Curate featured content"])
    end

    subgraph AISYS["«system» AI Verification"]
      AI_V(["Verify store / product"])
    end

    C --> UC_AUTH
    C --> UC_BROWSE
    C --> UC_ORDER
    C --> UC_APPLY

    S --> UC_AUTH
    S --> UC_STORE
    S --> UC_PROD
    S --> UC_AN
    S --> UC_UPG
    S --> UC_SALE

    A --> UC_AUTH
    A --> UC_REV
    A --> UC_MOD
    A --> UC_SUSP
    A --> UC_FEAT
    A --> UC_CHAT

    UC_APPLY -. "«triggers»" .-> UC_REV
    UC_STORE -. "«verified by AI»" .-> AI_V
    UC_PROD  -. "«verified by AI»" .-> AI_V
    AI_V     -. "«auto-flag»" .-> UC_MOD

    classDef actor    fill:#FFFFFF,stroke:#1E40AF,stroke-width:2.5px,color:#1E293B
    classDef shared   fill:#DBEAFE,stroke:#1D4ED8,stroke-width:2px,color:#1E293B
    classDef customer fill:#FEF3C7,stroke:#D97706,stroke-width:2px,color:#1E293B
    classDef seller   fill:#DCFCE7,stroke:#16A34A,stroke-width:2px,color:#1E293B
    classDef admin    fill:#FCE7F3,stroke:#BE185D,stroke-width:2px,color:#1E293B
    classDef aicase   fill:#EDE9FE,stroke:#7C3AED,stroke-width:2px,color:#1E293B

    class C,S,A actor
    class UC_AUTH shared
    class UC_BROWSE,UC_ORDER,UC_APPLY customer
    class UC_STORE,UC_PROD,UC_AN,UC_UPG,UC_SALE seller
    class UC_REV,UC_MOD,UC_SUSP,UC_FEAT,UC_CHAT admin
    class AI_V aicase
