@startuml seq-verify

skinparam defaultFontName Helvetica
skinparam defaultFontSize 12
skinparam backgroundColor #FFFFFF
skinparam sequenceArrowThickness 1.2
skinparam sequenceParticipantBorderThickness 1.5

skinparam sequence {
  ActorBackgroundColor       #FFFFFF
  ActorBorderColor           #1E40AF
  ActorFontColor             #111111
  ParticipantBackgroundColor #F5F5F5
  ParticipantBorderColor     #1E40AF
  ParticipantFontColor       #111111
  LifeLineBorderColor        #1E40AF
  ArrowColor                 #1E40AF
  ArrowFontColor             #111111
  GroupBackgroundColor       #EFF6FF
  GroupBorderColor           #1E40AF
  NoteBackgroundColor        #F5F5F5
  NoteBorderColor            #1E40AF
}

actor       "Seller"                            as S
participant "React SPA"                         as FE
participant "NestJS API"                        as BE
participant "Product / Store Module"            as PM
database    "MariaDB"                           as DB
participant "n8n Webhook\n(cheebo-ai-verify)"   as N8N
participant "LLM\n(Gemini / Groq)"              as LLM
actor       "Administrator"                     as A

note over S, DB
  Same workflow applies to both product and store creation
end note

S  -> FE : Create product or store
FE -> BE : POST /product or POST /store
BE -> PM : create(dto)
PM -> DB : INSERT entity\n(aiReviewed=false, adminReviewed=false)
PM --> BE : entity
BE -> N8N : POST cheebo-ai-verify\n{ entityId, type, name, description, images }

N8N -> LLM : Evaluate against marketplace rules
LLM --> N8N : { decision, rationale }
N8N -> BE : PATCH /verify-callback\n{ entityId, type, decision, rationale }
BE -> PM : applyAIDecision(entityId, decision)
PM -> DB : UPDATE entity SET aiReviewed=true,\naiReviewNote=rationale

alt Auto-approved
  BE --> S : Entity becomes visible (aiReviewed=true)
else Flagged / borderline
  BE --> A : Visible in admin moderation queue
  A -> FE : Open moderation panel
  FE -> BE : GET /verification/pending
  A -> FE : Approve / reject
  FE -> BE : PATCH /verify-override
  BE -> PM : applyAdminOverride()
  PM -> DB : UPDATE entity SET adminReviewed=true,\naiReviewed=false
end

@enduml
