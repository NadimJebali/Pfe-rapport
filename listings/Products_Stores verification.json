      "parameters": {
        "jsCode": "// Turn the images array into one item per image so each is screened.\nconst b = $json.body ?? {};\nconst images = Array.isArray(b.images) ? b.images : [];\nreturn images.map((path) => ({ json: { imagePath: path }, pairedItem: { item: 0 } }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -180,
        200
      ],
      "id": "a0000000-1111-2222-3333-444455556666",
