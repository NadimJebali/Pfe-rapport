      ],
      "id": "b1a2c3d4-1111-2222-3333-444455556666",
      "name": "Download Image"
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Decide whether this marketplace submission is appropriate for a general-audience e-commerce platform. Judge BOTH the attached image and the text below.\nType: {{ $('Webhook').item.json.body.type }}\nName: {{ $('Webhook').item.json.body.name }}\nDescription: {{ $('Webhook').item.json.body.description }}",
        "messages": {
          "messageValues": [
            {
              "message": "You are a strict marketplace content moderator. Flag the submission if the IMAGE or the text shows nudity or sexual content, weapons, illegal drugs, hate symbols, graphic violence, or anything else inappropriate for a general-audience e-commerce marketplace -- even when the name and description look innocent. Base your decision primarily on what the image actually shows. Reply ONLY with valid minified JSON in exactly this shape: {\"decision\":\"approved\"|\"flagged\",\"reason\":\"short explanation\"}. No markdown, no code fences, no extra text."
            },
            {
              "type": "HumanMessagePromptTemplate",
              "messageType": "imageBinary"
            }
          ]
        }
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.6,
      "position": [
        260,
        200
      ],
      "id": "c2b3d4e5-2222-3333-4444-555566667777",
      "name": "Moderate"
    },
    {
      "parameters": {
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1.1,
      "position": [
        260,
        420
      ],
      "id": "fbfda46b-af43-45f3-9382-7e1fb0114023",
      "name": "Google Gemini Chat Model1",
      "credentials": {
        "googlePalmApi": {
          "id": "Lgn8GBOiIQdPIrUF",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Aggregate the per-image decisions: flag the submission if ANY image is flagged.\nconst items = $input.all();\nlet decision = \"approved\";\nconst reasons = [];\nfor (const it of items) {\n  const raw = it.json.output ?? it.json.text ?? \"\";\n  let parsed;\n  try {\n    const cleaned = raw.replace(/```json?|```/g, \"\").trim();\n    parsed = JSON.parse(cleaned);\n  } catch {\n    parsed = { decision: \"flagged\", reason: \"AI response could not be parsed.\" };\n  }\n  if (![\"approved\", \"flagged\"].includes(parsed.decision)) {\n    parsed.decision = \"flagged\";\n    parsed.reason = parsed.reason ?? \"Unexpected AI response.\";\n  }\n  if (parsed.decision === \"flagged\") {\n    decision = \"flagged\";\n    if (parsed.reason) reasons.push(parsed.reason);\n  }\n}\nconst reason = decision === \"flagged\" ? reasons.join(\" | \") : \"All images passed AI screening.\";\nreturn [{ json: { decision, reason }, pairedItem: { item: 0 } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        200
      ],
      "id": "1e7b8874-d3e9-4055-a9d2-9abf6a08e074",
      "name": "Combine Results"
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=http://backend:3000/{{ $('Webhook').item.json.body.type }}/{{ $('Webhook').item.json.body.id }}/ai-review",
        "sendHeaders": true,
