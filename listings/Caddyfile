# Global options — ACME account email for Let's Encrypt certificate notices.
{
	email {$ACME_EMAIL}
}

# Canonicalise www -> apex so there is a single HTTPS origin, which matches
# the backend's BETTER_AUTH_URL / trustedOrigins and keeps cookies consistent.
www.{$DOMAIN_NAME} {
	redir https://{$DOMAIN_NAME}{uri} permanent
}

# Public entrypoint. Caddy obtains and renews the TLS certificate
# automatically (HTTP-01 / TLS-ALPN-01) and terminates HTTPS here, then
# reverse-proxies to the internal Nginx frontend container, which serves the
# SPA and forwards /api and the SSE stream to the backend.
{$DOMAIN_NAME} {
	encode gzip

	# Security response headers. Conservative baseline that does not break the
	# SPA, the /api proxy, the SSE stream, or Stripe checkout (no CSP — a strict
	# policy would need per-asset auditing first).
	header {
		# HSTS — force HTTPS for a year, including subdomains (www is HTTPS).
		# No `preload` so we keep the option to roll back.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Stop MIME sniffing.
		X-Content-Type-Options "nosniff"
		# We embed Stripe's iframe (outbound); this only restricts who may frame
		# us, so SAMEORIGIN is safe.
		X-Frame-Options "SAMEORIGIN"
		# Send origin only on cross-origin navigations.
		Referrer-Policy "strict-origin-when-cross-origin"
		# Don't advertise the server software.
		-Server
	}

	reverse_proxy frontend:8080
}
